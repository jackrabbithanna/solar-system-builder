                    <child>
                      <object class="GtkGrid" id="body_properties_grid">
                        <property name="column-spacing">10</property>
                        <property name="row-spacing">8</property>
                        <child><object class="GtkLabel"><property name="label" translatable="yes">Distance Unit</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkDropDown" id="distance_unit_dropdown"><property name="tooltip-text" translatable="yes">Position editor distance unit</property><layout><property name="column">1</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label" translatable="yes">Kind</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">1</property></layout></object></child>
                        <child><object class="GtkDropDown" id="body_kind_dropdown"><layout><property name="column">1</property><property name="row">1</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label" translatable="yes">Parent</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">2</property></layout></object></child>
                        <child><object class="GtkDropDown" id="body_parent_dropdown"><layout><property name="column">1</property><property name="row">2</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label" translatable="yes">Mass (kg)</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">3</property></layout></object></child>
                        <child><object class="GtkEntry" id="mass_entry"><layout><property name="column">1</property><property name="row">3</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label" translatable="yes">Radius (m)</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">4</property></layout></object></child>
                        <child><object class="GtkEntry" id="radius_entry"><layout><property name="column">1</property><property name="row">4</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label" translatable="yes">Color</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">5</property></layout></object></child>
                        <child><object class="GtkColorDialogButton" id="body_color_button"><property name="dialog"><object class="GtkColorDialog"/></property><layout><property name="column">1</property><property name="row">5</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label" translatable="yes">Visible</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">6</property></layout></object></child>
                        <child><object class="GtkSwitch" id="body_visible_switch"><property name="halign">start</property><layout><property name="column">1</property><property name="row">6</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label" translatable="yes">Trail</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">7</property></layout></object></child>
                        <child><object class="GtkSwitch" id="body_trail_switch"><property name="halign">start</property><layout><property name="column">1</property><property name="row">7</property></layout></object></child>
                        <child><object class="GtkLabel" id="x_label"><property name="label" translatable="yes">X (AU)</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">8</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="x_spin"><property name="digits">4</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">-100</property><property name="upper">100</property><property name="step-increment">0.01</property><property name="page-increment">1</property></object></property><layout><property name="column">1</property><property name="row">8</property></layout></object></child>
                        <child><object class="GtkLabel" id="y_label"><property name="label" translatable="yes">Y (AU)</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">9</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="y_spin"><property name="digits">4</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">-100</property><property name="upper">100</property><property name="step-increment">0.01</property><property name="page-increment">1</property></object></property><layout><property name="column">1</property><property name="row">9</property></layout></object></child>
                        <child><object class="GtkLabel" id="z_label"><property name="label" translatable="yes">Z (AU)</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">10</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="z_spin"><property name="digits">4</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">-100</property><property name="upper">100</property><property name="step-increment">0.01</property><property name="page-increment">1</property></object></property><layout><property name="column">1</property><property name="row">10</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label" translatable="yes">VX (m/s)</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">11</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="vx_spin"><property name="adjustment"><object class="GtkAdjustment"><property name="lower">-1000000000</property><property name="upper">1000000000</property><property name="step-increment">10</property><property name="page-increment">1000</property></object></property><layout><property name="column">1</property><property name="row">11</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label" translatable="yes">VY (m/s)</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">12</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="vy_spin"><property name="adjustment"><object class="GtkAdjustment"><property name="lower">-1000000000</property><property name="upper">1000000000</property><property name="step-increment">10</property><property name="page-increment">1000</property></object></property><layout><property name="column">1</property><property name="row">12</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label" translatable="yes">VZ (m/s)</property><property name="xalign">0</property><layout><property name="column">0</property><property name="row">13</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="vz_spin"><property name="adjustment"><object class="GtkAdjustment"><property name="lower">-1000000000</property><property name="upper">1000000000</property><property name="step-increment">10</property><property name="page-increment">1000</property></object></property><layout><property name="column">1</property><property name="row">13</property></layout></object></child>
                        <child><object class="GtkLabel" id="state_origin_label"><property name="xalign">0</property><style><class name="dim-label"/></style><layout><property name="column">0</property><property name="row">14</property><property name="column-span">2</property></layout></object></child>
                        <child><object class="GtkButton" id="apply_body_button"><property name="label" translatable="yes">Apply Body Changes</property><property name="halign">end</property><style><class name="suggested-action"/></style><layout><property name="column">0</property><property name="row">15</property><property name="column-span">2</property></layout></object></child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>
      </object>
    </property>
